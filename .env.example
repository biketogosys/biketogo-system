# BikeTogo System — variáveis de ambiente de produção
# Copiar para `.env` na raiz do projeto na VPS (nunca commitar o .env real).

# ── Obrigatórias ─────────────────────────────────────────────────────────────

# String de conexão do Postgres do Supabase (Settings → Database → Connection
# string). Para processo Node persistente (VPS), use o modo "Session" do
# pooler (porta 5432) ou a conexão direta — NÃO o "Transaction" pooler
# (porta 6543, feito pra serverless/muitas conexões curtas).
DATABASE_URL=postgresql://postgres.xxxxx:SENHA@aws-0-xx-xxxx.pooler.supabase.com:5432/postgres

# Segredo pra assinar o cookie de sessão (JWT). Gerar um valor aleatório forte,
# ex.: `openssl rand -base64 48`. Nunca reutilizar entre ambientes.
JWT_SECRET=

NODE_ENV=production

# Porta que o processo Node escuta (o Nginx faz proxy_pass pra ela). Padrão 3000.
PORT=3000

# ── Supabase (auth admin do painel + Storage) ────────────────────────────────
# Painel → Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Storage S3-compatível (Supabase Storage) ─────────────────────────────────
# Painel → Project Settings → Storage → S3 Connection. Sem essas 5 variáveis
# preenchidas, o app cai no fallback de disco local (.dev-storage/) — não
# recomendado em produção (sem redundância/backup).
S3_ENDPOINT=https://xxxxx.supabase.co/storage/v1/s3
S3_REGION=sa-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Opcional ──────────────────────────────────────────────────────────────────

# Restringe o CORS do widget público (/reservar, publicApi.bikeSizes) à origem
# exata do site (ex.: https://biketogofloripa.com.br). Sem isso, aceita
# qualquer origem — funciona, mas é menos restrito.
SHOPIFY_ALLOWED_ORIGIN=

# ── NÃO usar em produção fora do sandbox Manus (legado, deixar vazio) ────────
# VITE_APP_ID=
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
